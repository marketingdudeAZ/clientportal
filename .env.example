# ═══════════════════════════════════════════════════════════════════════════
# RPM Living Client Portal — environment variables
#
# Copy to .env and fill in values. Grouped by integration. Every var below
# is actually read somewhere in the code; unused vars were removed 2026-04-24.
# ═══════════════════════════════════════════════════════════════════════════

# ─── HubSpot (core) ─────────────────────────────────────────────────────────
# Private app token with CMS + HubDB + CRM scopes.
HUBSPOT_API_KEY=your_private_app_token
HUBSPOT_PORTAL_ID=your_portal_id

# ─── HubDB tables ───────────────────────────────────────────────────────────
# One ID per table. Create via scripts/create_hubdb_tables_v2.py.
HUBDB_ASSET_TABLE_ID=
HUBDB_RECOMMENDATIONS_TABLE_ID=
HUBDB_AI_MENTIONS_TABLE_ID=
HUBDB_AM_PRIORITY_TABLE_ID=
HUBDB_BUDGET_TIERS_TABLE_ID=
HUBDB_CONTENT_BRIEFS_TABLE_ID=
HUBDB_CONTENT_DECAY_TABLE_ID=
HUBDB_SEO_KEYWORDS_TABLE_ID=
HUBDB_SEO_COMPETITORS_TABLE_ID=
HUBDB_PAID_KEYWORDS_TABLE_ID=
HUBDB_BRIEF_DRAFTS_TABLE_ID=
# Onboarding/discovery + Fluency Blueprint pipeline. Create via
# scripts/create_hubdb_onboarding_tables.py.
HUBDB_ONBOARDING_INTAKE_TABLE_ID=
HUBDB_GAP_RESPONSES_TABLE_ID=
HUBDB_BLUEPRINT_VARIABLES_TABLE_ID=
HUBDB_BLUEPRINT_TAGS_TABLE_ID=
HUBDB_BLUEPRINT_ASSETS_TABLE_ID=

# ─── Google Sheets (enrollment data, spend sheets) ──────────────────────────
GOOGLE_SHEETS_ID=1jRqmEzhOIe72zgwIOcDZTyvde_Y0_jvayaLTZhva9mk
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service_account.json

# ─── BigQuery (ninjacat_metrics, report_insights, red_light_history, SEO) ───
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET_DEV=rpm_portal_dev
BIGQUERY_DATASET_PROD=rpm_portal
BIGQUERY_SEO_AUDIT_TABLE=seo_audit_history
BIGQUERY_SEO_RANKS_TABLE=seo_ranks_history
# Either path to a JSON file OR the JSON content inline.
BIGQUERY_SERVICE_ACCOUNT_JSON=path/to/service_account.json

# ─── DataForSEO (keyword research, SERP, rank tracking) ─────────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_BASE_URL=https://api.dataforseo.com
DATAFORSEO_DEFAULT_LOCATION=United States
DATAFORSEO_DEFAULT_LANGUAGE=en

# ─── Anthropic (brief drafter, scene planner, KB writer) ────────────────────
ANTHROPIC_API_KEY=

# ─── ClickUp (task routing for onboarding, paid, SEO, social, reputation) ───
CLICKUP_API_KEY=
CLICKUP_LIST_ONBOARDING=
CLICKUP_LIST_PAID_MEDIA=
CLICKUP_LIST_SEO=
CLICKUP_LIST_SOCIAL=
CLICKUP_LIST_REPUTATION=

# ─── Knowledge base sync (Google Drive folder + audit sheet) ────────────────
KB_DRAFT_FOLDER_ID=
KB_LOG_SHEET_ID=

# ─── Flask server / webhooks ────────────────────────────────────────────────
# WEBHOOK_SECRET signs the configurator submission payload (X-Hub-Signature-256)
# and backs the portal request-signature helper in auth.py.
WEBHOOK_SECRET=your_hmac_secret_key
WEBHOOK_PORT=8443
# FLASK_ENV is mainly used to relax CORS for localhost. Webhook signature
# checks for HeyGen / Creatify are opt-in: leave their secrets unset and
# the server accepts unsigned callbacks. Set the secret + enable signing in
# the provider dashboard to flip on strict validation.
FLASK_ENV=production
# CRON_MODE=1 runs seo_refresh_cron.py in batch mode instead of serving HTTP.
CRON_MODE=

# ─── Portal URLs ────────────────────────────────────────────────────────────
PORTAL_BASE_URL=https://info.rpmliving.com/client-portal
# Base URL of this Flask service; used when webhooks must embed a callback.
WEBHOOK_SERVER_URL=https://clientportal-production.up.railway.app

# ─── NinjaCat (marketing dashboards) ────────────────────────────────────────
NINJACAT_DASHBOARD_ID=16866
# Optional GCS bucket NinjaCat exports land in.
NINJACAT_EXPORT_BUCKET=

# ─── Video providers (Marquee) ──────────────────────────────────────────────
# Default provider when /api/video-enroll omits the `provider` field.
VIDEO_PROVIDER_DEFAULT=creatify

# Creatify
CREATIFY_API_ID=
CREATIFY_API_KEY=
CREATIFY_TEMPLATE_ID=
# Webhook signing — opt-in. Leave blank to accept unsigned callbacks
# (current setup). Set + enable signing in Creatify's dashboard to enforce.
CREATIFY_WEBHOOK_SECRET=

# HeyGen (alternative provider; leave API key blank to disable)
HEYGEN_API_KEY=
HEYGEN_BASE_URL=https://api.heygen.com
# Same opt-in pattern as Creatify above.
HEYGEN_WEBHOOK_SECRET=

# ─── ApartmentIQ (market data) ──────────────────────────────────────────────
# Note: non-standard casing is what the code reads (apartmentiq_client.py).
ApartmentIQ_Token=

# ─── Internal / ops ─────────────────────────────────────────────────────────
# Shared secret for server-to-server calls: /api/internal/* and cron triggers.
# Sent as X-Internal-Key header.
INTERNAL_API_KEY=
# Comma-separated property UUIDs allowed to use paid SEO features.
# Leave blank to allow all.
SEO_PROPERTY_UUID_ALLOWLIST=

# ─── Fluency Blueprint export ───────────────────────────────────────────────
# Phase 1 (default): leave FLUENCY_API_KEY blank. The CsvExporter writes
#   Bulk Manage CSVs under FLUENCY_DROPZONE_PATH/<property_uuid>/ and
#   Fluency picks them up via sFTP polling (configured on Fluency's side).
# Phase 2: set FLUENCY_API_KEY (issued by Fluency support after API access
#   is enabled on your tier) — the exporter switches to the REST API
#   automatically. Docs: https://fluency.readme.io/reference/getting-started-with-your-api
FLUENCY_DROPZONE_PATH=
FLUENCY_API_KEY=
FLUENCY_API_BASE_URL=https://api.fluency.inc
